#!/usr/bin/env python3
"""
SentinelAI — Wazuh Webhook Integration Script
Location on VM1: /var/ossec/integrations/custom-webhook

This script is executed by wazuh-integratord whenever an alert at or above
the configured severity level (10) fires. It reads the alert JSON and forwards
it via HTTP POST to the n8n webhook on VM2.

Permissions required:
    sudo chmod 750 /var/ossec/integrations/custom-webhook
    sudo chown root:wazuh /var/ossec/integrations/custom-webhook

Wazuh passes these arguments:
    sys.argv[1] = path to the alert JSON file
    sys.argv[2] = API key (unused for webhook)
    sys.argv[3] = hook_url from ossec.conf integration block
"""

import sys
import json
import requests

# The alert file is the first argument passed by integratord
alert_file = sys.argv[1]

# The hook URL is the third argument (from ossec.conf <hook_url>)
# Falls back to a default if not provided
hook_url = sys.argv[3] if len(sys.argv) > 3 else 'http://192.168.1.31:5678/webhook/wazuh-alerts'


def main():
    try:
        # Read the alert that triggered this integration
        with open(alert_file, 'r') as f:
            alert = json.load(f)

        # Forward the full alert to n8n
        response = requests.post(
            hook_url,
            json=alert,
            headers={'Content-Type': 'application/json'},
            timeout=10
        )

        # Log success to integrations.log (visible via tail)
        print(f"Alert forwarded to n8n. Status: {response.status_code}")

    except FileNotFoundError:
        print(f"Error: alert file not found: {alert_file}", file=sys.stderr)
        sys.exit(1)
    except requests.exceptions.RequestException as e:
        print(f"Error: failed to POST to {hook_url}: {e}", file=sys.stderr)
        sys.exit(1)
    except Exception as e:
        print(f"Error: {e}", file=sys.stderr)
        sys.exit(1)


if __name__ == '__main__':
    main()
